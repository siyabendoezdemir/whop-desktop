{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Whop",
  "mainBinaryName": "Whop",
  "version": "0.1.0",
  "identifier": "technologies.ciya.whop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'",
      "dangerousDisableAssetCspModification": false,
      "capabilities": ["main-capability"]
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "category": "SocialNetworking",
    "shortDescription": "Unofficial personal-use desktop wrapper for whop.com",
    "longDescription": "Whop is an unofficial, personal-use desktop wrapper around whop.com. It is not affiliated with, endorsed by, or distributed by Whop.",
    "copyright": "Personal use. Unofficial wrapper, not affiliated with Whop.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "11.0",
      "entitlements": "Entitlements.plist"
    }
  }
}
